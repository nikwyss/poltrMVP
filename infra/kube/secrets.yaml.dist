apiVersion: v1
kind: Secret
metadata:
  name: pds-secrets
  namespace: poltr
type: Opaque
stringData:
  PDS_ADMIN_PASSWORD: "..."
  PDS_JWT_SECRET: "..."
  PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX: "..."
  # Generate did:plc using PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX and register at plc.directory
  PDS_SERVER_DID: "did:plc:..."
  PDS_SERVICE_HANDLE_DOMAINS: ".id.poltr.ch"
  PDS_BSKY_APP_VIEW_URL: "https://app.poltr.info"
  PDS_BSKY_APP_VIEW_DID: "did:web:app.poltr.info"
  PDS_REPORT_SERVICE_URL: "https://ozone.poltr.info"
  PDS_REPORT_SERVICE_DID: "did:plc:5ecl3anpfxtmn2szxsm2mjhf"
  PDS_CRAWLERS: "https://bsky.network"
  PDS_HOSTNAME: "pds2.poltr.info"
  PDS_PORT: "2583"
  PDS_BLOBSTORE: "disk"
  PDS_BLOBSTORE_DISK_LOCATION: "/data/blobs"
  PDS_DATA_DIR: "/data"
  # Account creation is gated by the appview (email magic-link + MAX_PDS_ACCOUNTS).
  # Keep invites REQUIRED so nobody can create accounts directly on the PDS and
  # bypass that gate. The appview creates accounts via the admin API (which is
  # exempt from invite-required).
  PDS_INVITE_REQUIRED: "true"
  PDS_INTERNAL_URL: "http://pds.poltr.svc.cluster.local"
  PDS_PUBLIC_HANDLE: "id.poltr.ch"
  # --- Rate limiting -----------------------------------------------------------
  # Defense against a flood of self-signed writes (e.g. someone creating accounts
  # and spamming arguments/comments/likes straight into their own repos, bypassing
  # the appview's per-user quotas). The PDS limiter is points-based per account
  # (CREATE=3/UPDATE=2/DELETE=1, default 5000/h & 35000/day) plus a per-IP request
  # cap. Single PDS replica → the in-memory limiter is process-global (no Redis
  # needed). Set explicitly so the behaviour doesn't depend on image defaults.
  PDS_RATE_LIMITS_ENABLED: "true"
  # Bypass key for trusted internal bulk writers (community writer, import
  # scripts): send header `x-ratelimit-bypass: <this value>` to skip the limiter.
  # Generate: openssl rand -hex 32. Leave empty to disable the bypass entirely.
  # NOTE: clients must opt in by sending the header — see writer/import follow-up.
  PDS_RATE_LIMIT_BYPASS_KEY: "..."
  # Community credentials now stored per-ballot in community_accounts table.
  # Seed the table with the initial community account DID + encrypted password.
---
apiVersion: v1
kind: Secret
metadata:
  name: indexer-secrets
  namespace: poltr
type: Opaque
stringData:
  INDEXER_POSTGRES_URL: "postgresql://indexer:...@allforone-postgres:5432/appview"
  BACKFILL_PORT: "3001"
  # Projektor-seitige Akzeptanz-Pipeline (Phase 3/4): non-community user-Records
  # in app_acceptance_queue stagen. Gemeinsam mit den appview-Flags + writer-secrets
  # schalten. (Crosspost läuft jetzt im Writer, nicht hier — Key war stale/ungenutzt.)
  ACCEPTANCE_PIPELINE_ENABLED: "false"
  # POLTR_LANGUAGES / POLTR_DEFAULT_LANGUAGE come from appview-secrets via
  # indexer.yaml (secretKeyRef) — single source of truth, do not duplicate here.
---
apiVersion: v1
kind: Secret
metadata:
  name: writer-secrets
  namespace: poltr
type: Opaque
stringData:
  # Interne Schreib-Seite (community-writer). NUR writer-spezifisches hier; alles
  # Geteilte (Master-Key, Peer-Review-Flag, Log-Level, PDS_INTERNAL_URL) erbt
  # writer.yaml via secretKeyRef aus appview-secrets/pds-secrets — keine Duplikate.
  # Optionales mit Code-Default (Poll-Intervalle, Frontend-URL) ist weggelassen.
  #
  # Eigener DB-User 'writer' (NICHT allforone) — siehe add-pod-roles.sql.
  APPVIEW_POSTGRES_URL: "postgresql://writer:PASSWORD@allforone-postgres:5432/appview"
  # Der Writer ist der Crosspost-Runner (appview-API tut es nicht mehr).
  APPVIEW_CROSSPOST_ENABLED: "true"
  # Akzeptanz-Pipeline (Phase 3/4): gemeinsam mit indexer + appview-Flags schalten.
  ACCEPTANCE_PIPELINE_ENABLED: "false"
  # Translation-Worker (Phase 5, aus appview hierher gezogen). Infomaniak AI Tools,
  # Apertus by default. POLTR_LANGUAGES/DEFAULT erbt writer.yaml aus appview-secrets.
  APPVIEW_TRANSLATE_ENABLED: "true"
  APPVIEW_TRANSLATE_BASE_URL: "https://api.infomaniak.com"
  APPVIEW_TRANSLATE_PRODUCT_ID: "..."        # GET /1/ai  (Infomaniak product id)
  APPVIEW_TRANSLATE_API_KEY: "..."           # Infomaniak Bearer token
  APPVIEW_TRANSLATE_MODEL: "swiss-ai/Apertus-70B-Instruct-2509"
  APPVIEW_TRANSLATE_POLL_INTERVAL_SECONDS: "30"
  APPVIEW_TRANSLATE_BATCH_SIZE: "20"
  APPVIEW_TRANSLATE_COMMENTS_ENABLED: "false"
  APPVIEW_TRANSLATE_TOPICS_ENABLED: "true"
---
kind: Secret
metadata:
  name: appview-secrets
  namespace: poltr
type: Opaque
stringData:
  # Eigener DB-User 'appview' (NICHT allforone, kein Superuser) — add-pod-roles.sql.
  APPVIEW_POSTGRES_URL: "postgresql://appview:PASSWORD@allforone-postgres:5432/appview"
  APPVIEW_HOSTNAME: "app.poltr.info"
  APPVIEW_PORT: "2580"
  APPVIEW_LABELER_URL: "http://labeler.poltr.svc.cluster.local:2587"
  APPVIEW_SERVER_DID: "did:web:app.poltr.info"
  APPVIEW_SMTP_HOST: "mail.infomaniak.com"
  APPVIEW_SMTP_PORT: "587"
  APPVIEW_SMTP_USE_TLS: "true"
  APPVIEW_FROM_EMAIL: "wysdom@ik.me "
  APPVIEW_SMTP_PASSWORD: "......."
  APPVIEW_SMTP_USER: "....."
  # Shared secret so the frontend proxy may forward the real client IP to the rate
  # limiter. Single source of truth — the frontend inherits it via a secretKeyRef
  # to appview-secrets in frontend.yaml. Generate: openssl rand -hex 32.
  # See doc/SECURITY_AUTH.md #1.
  APPVIEW_PROXY_SECRET: "......"
  # Per-user content-creation quotas (per user · ballot). See src/routes/deliberation/quota.py.
  APPVIEW_ARGUMENT_DAILY_LIMIT: "2"
  APPVIEW_ARGUMENT_BALLOT_LIMIT: "10"
  APPVIEW_COMMENT_DAILY_LIMIT: "10"
  APPVIEW_COMMENT_BALLOT_LIMIT: "50"
  # Global hourly circuit breaker for outbound auth emails. See doc/SECURITY_AUTH.md #4.
  APPVIEW_AUTH_EMAIL_ALERT_PER_HOUR: "40"
  APPVIEW_AUTH_EMAIL_CAP_PER_HOUR: "100"
  APPVIEW_FRONTEND_URL: "https://poltr.ch"
  # Key-Split: getrennte Master-Keys für USER-Creds (auth_creds) und COMMUNITY-
  # Creds (community_accounts). Auf Dev DENSELBEN Wert eintragen. writer + cms
  # erben NUR den COMMUNITY-Key via secretKeyRef; appview selbst nutzt nur den USER-Key.
  APPVIEW_USER_CREDS_MASTER_KEY_B64: "..."
  APPVIEW_COMMUNITY_CREDS_MASTER_KEY_B64: "..."
  APPVIEW_LOG_LEVEL: "DEBUG"
  APPVIEW_PEER_REVIEW_ENABLED: "false"
  APPVIEW_PEER_REVIEW_QUORUM: "10"
  APPVIEW_PEER_REVIEW_INVITE_PROBABILITY: "0.35"
  APPVIEW_PEER_REVIEW_POLL_INTERVAL_SECONDS: "60"
  APPVIEW_PEER_REVIEW_CRITERIA: '[{"key":"factual_accuracy","label":"Factual Accuracy"},{"key":"relevance","label":"Relevance to Ballot"},{"key":"clarity","label":"Clarity"},{"key":"unity_of_thought","label":"Unity of Thought"},{"key":"non_duplication","label":"Non-Duplication"}]'
  APPVIEW_SESSION_LIFETIME_DAYS: "7"
  # ATProto-native Pipeline (Phase 3/4) — appview-Schreibpfad: user-authored
  # Argumente/Responses ins EIGENE User-Repo statt ins Community-Repo. Default aus.
  # Nur zusammen mit indexer + writer (ACCEPTANCE_PIPELINE_ENABLED) einschalten.
  APPVIEW_ARGS_USER_REPO_ENABLED: "false"
  APPVIEW_RESPONSES_USER_REPO_ENABLED: "false"
  # Phase 6: appview schreibt peerreview.request ins User-Repo (max. 1×/aktiver Tag)
  # statt selbst zuzuteilen; der Writer führt die Zuteilung aus.
  APPVIEW_REVIEW_REQUESTS_USER_REPO_ENABLED: "false"
  # (Crosspost lief früher hier; ist in writer-secrets gewandert.)
  APPVIEW_FEED_GENERATOR_DID: "did:web:app.poltr.info"
  # Content languages — single source of truth. The indexer consumes these
  # same keys via indexer.yaml (secretKeyRef → appview-secrets).
  POLTR_LANGUAGES: "de-CH,en-GB"
  POLTR_DEFAULT_LANGUAGE: "de-CH"
  # (Translation-Worker ist in Phase 5 in den Writer gewandert → APPVIEW_TRANSLATE_*
  #  stehen jetzt in writer-secrets. POLTR_LANGUAGES/DEFAULT bleiben hier —
  #  appview-API + indexer brauchen sie auch.)

  # ---
  # apiVersion: v1
  # kind: Secret
  # metadata:
  #   name: labeler-secrets
  #   namespace: poltr
  # type: Opaque
  # stringData:
  #   LABELER_HOSTNAME: "labeler.poltr.info"
  #   LABELER_PORT: "2587"
  #   LABELER_POSTGRES_URL: "postgresql://..."
  #   LABELER_REDIS_URL: "redis://labeler-redis:6379/0"
  #   LABELER_JWT_SECRET: "..."
  #   LABELER_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX: "..."
  #   LABELER_SERVER_DID: "did:web:labeler.poltr.info"#
---
apiVersion: v1
kind: Secret
metadata:
  name: ozone-secrets
  namespace: poltr
type: Opaque
stringData:
  OZONE_SERVER_DID: "did:plc:5ecl3anpfxtmn2szxsm2mjhf"
  OZONE_PUBLIC_URL: "https://ozone.poltr.info"
  # Eigene, auf die ozone-DB beschränkte Rolle (NICHT allforone) — siehe
  # infra/scripts/postgres/harden-service-roles.sql. Ozone hat keinen Zugriff auf appview.
  OZONE_DB_POSTGRES_URL: "postgresql://ozone:PASSWORD@allforone-postgres:5432/ozone"
  OZONE_ADMIN_DIDS: "did:plc:awdi4imosf4o6h6iewj23kji,..."
  OZONE_ADMIN_PASSWORD: "..."
  OZONE_SIGNING_KEY_HEX: "..."
  OZONE_PDS_URL: "https://pds2.poltr.info"
  OZONE_PDS_DID: "did:web:pds2.poltr.info"
  OZONE_DID_PLC_URL: "https://plc.directory"
  OZONE_DB_MIGRATE: "1"

---
apiVersion: v1
kind: Secret
metadata:
  name: verifier-secrets
  namespace: poltr
type: Opaque
stringData:
  EXTERNAL_URL: "https://verifier.poltr.info"
  VERIFIER_DID: "did:web:verifier.poltr.info"
  DID_VERIFICATION_METHOD: "did:web:verifier.poltr.info#atproto"
  SIGNING_KEY: "...."
---
apiVersion: v1
kind: Secret
metadata:
  name: eidproto-secrets
  namespace: poltr
type: Opaque
stringData:
  # ============================================
  # EID-PROTO Runtime Environment Variables
  # ============================================
  # Note: NEXT_PUBLIC_* vars are build-time (set via Dockerfile ARGs)
  #       These are runtime server-side secrets only

  # SWIYU eID Verification API
  EIDPROTO_EID_VERIFIER_API: "https://verifier.poltr.info/api/v1/verification-requests"

  # Trusted issuer DID for eID credentials
  EIDPROTO_EID_TRUSTED_ISSUER_DID: "did:tdw:..."

  # Secret for hashing AHV numbers
  # IMPORTANT: Use same value as APPVIEW_EID_HASH_SECRET for cross-service compatibility
  EIDPROTO_EID_HASH_SECRET: "your-secret-here"

  # Ed25519 signing key seed (32 bytes, base64 encoded)
  # Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
  EIDPROTO_SIGNING_KEY_SEED: "base64-encoded-32-byte-seed"

  # JWT secret for session/state tokens
  EIDPROTO_JWT_SECRET: "your-jwt-secret-here"

  # Service DID (must match /.well-known/did.json)
  EIDPROTO_SERVER_DID: "did:web:eidproto.poltr.info"
---
apiVersion: v1
kind: Secret
metadata:
  name: allforone-postgres-secret
  namespace: poltr
type: Opaque
stringData:
  POSTGRES_USER: "..."
  POSTGRES_PASSWORD: "..."
---
apiVersion: v1
kind: Secret
metadata:
  name: cms-secrets
  namespace: poltr
type: Opaque
stringData:
  # Database connection (separate database on same PostgreSQL instance).
  # Eigene cms-Rolle (NICHT allforone) — siehe harden-service-roles.sql.
  CMS_DATABASE_URL: "postgresql://cms:PASSWORD@allforone-postgres:5432/cms"

  # Zugriff auf die appview-DB für Community-Creds + Taxonomie-Snapshot-Ledger.
  # Eng gescopte cms-Rolle: nur auth.community_accounts + app_taxonomy_snapshot.
  # Bewusst aus DIESEM Secret (cms@appview), nicht aus appview-secrets — das zeigt
  # auf die breitere appview-Rolle; cms nutzt seine eigene, eng gescopte cms-Rolle.
  APPVIEW_POSTGRES_URL: "postgresql://cms:PASSWORD@allforone-postgres:5432/appview"

  # Payload secret (generate with: openssl rand -base64 32)
  CMS_SECRET: "your-payload-secret-here"

  # Public URL for the CMS
  CMS_PUBLIC_SERVER_URL: "https://cms.poltr.info"

---
apiVersion: v1
kind: Secret
metadata:
  name: front-secrets
  namespace: poltr
type: Opaque
stringData:
  # AppView URL (server-only, used by API routes to proxy XRPC calls)
  APPVIEW_URL: "https://app.poltr.info"
  # NOTE: APPVIEW_PROXY_SECRET is NOT set here — the frontend inherits it from
  # appview-secrets via a secretKeyRef in frontend.yaml (single source of truth).
---
apiVersion: v1
kind: Secret
metadata:
  name: calculator-secrets
  namespace: poltr
type: Opaque
stringData:
  # LLM-Service für die Top-down Themen-Hierarchie. ANTHROPIC_API_KEY
  # erforderlich (sonst 503 auf den LLM-Endpoints; kein Mock-Fallback mehr).
  ANTHROPIC_API_KEY: "..."
  CALCULATOR_LLM_MODEL: "claude-sonnet-4-6"
  CALCULATOR_PORT: "3000"
  CALCULATOR_LOG_LEVEL: "INFO"
  # Postgres (AppView-Schema): liest app_arguments für die Topdown-Berechnung.
  CALCULATOR_POSTGRES_URL: "postgresql://calculator:...@allforone-postgres:5432/appview"
  # CMS-DB (read-only) für die amtliche Vorlagen-Beschreibung als Themen-Kontext.
  CALCULATOR_CMS_POSTGRES_URL: "postgresql://calculator:...@allforone-postgres:5432/cms"
---
apiVersion: v1
kind: Secret
metadata:
  name: cms-basic-auth
  namespace: poltr
# HTTP Basic Auth gate for the CMS admin at the edge (nginx-ingress).
# Consumed by the `cms-admin-ingress` (auth-secret annotation) in ingress.yaml —
# NOT mounted by any pod. The frontend/appview reach the CMS via the internal
# URL (CMS_INTERNAL_SERVER_URL) and bypass this gate.
#
# The `auth` value is one or more htpasswd lines "user:hash".
# Generate (htpasswd not required — use openssl):
#   printf "poltr-admin:%s\n" "$(openssl passwd -apr1 'CHANGE_ME')"
# Append more "user:hash" lines (separated by \n) for additional admins.
type: Opaque
stringData:
  auth: "poltr-admin:$apr1$CHANGE_ME_REPLACE_WITH_GENERATED_HASH"


