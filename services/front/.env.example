# PRIVATE
# ------------------
CMS_INTERNAL_SERVER_URL=https://....
APPVIEW_URL=http://localhost:3000
# Must match appview APPVIEW_PROXY_SECRET — lets the XRPC proxy forward the real
# client IP to the AppView rate limiter. Generate: openssl rand -hex 32.
APPVIEW_PROXY_SECRET=......

# PUBLIC
# ------------------

# App Password: allow users to create app passwords for external Bluesky clients
NEXT_PUBLIC_APP_PASSWORD_ENABLED=false

# E-ID Verification: enable swiyu E-ID verification flow
NEXT_PUBLIC_EID_VERIFICATION_ENABLED=false
# NEXT_PUBLIC_CMS_URL=http://localhost:3002 

# BCP-47 region-flavoured locales (Swiss flavours; English = British). These
# are build-time (NEXT_PUBLIC_*) and embedded into the client bundle.
NEXT_PUBLIC_POLTR_DEFAULT_LANGUAGE=de-CH
NEXT_PUBLIC_POLTR_LANGUAGES=de-CH,en-GB