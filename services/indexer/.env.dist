# ./services/indexer/.env  — Projektor/Indexer (firehose → Postgres)

# DB-Rolle 'indexer' (least privilege: kein pw-Zugriff auf governance_accounts).
INDEXER_POSTGRES_URL=postgresql://indexer:....@allforone-postgres:5432/appview

# Firehose-Quelle. FIREHOSE_URL überschreibt; sonst wss://${PDS_HOSTNAME}.
PDS_HOSTNAME=pds2.poltr.info
# FIREHOSE_URL=wss://pds2.poltr.info
# FIREHOSE_ENABLED=true
# FIREHOSE_MAX_RETRIES=...

# Backfill-Admin-HTTP (Cronjob ruft es) + Idle-Timeout.
BACKFILL_PORT=3001
# BACKFILL_IDLE_TIMEOUT_SEC=...

# Acceptance-Pipeline (ATProto-native): staged user-authored Records
# (ballot.argument / peerreview.response / peerreview.request) in
# app_acceptance_queue, die der community-writer abarbeitet. Läuft immer
# (kein Flag mehr) — die appview schreibt user-authored Records unbedingt ins
# User-Repo, also MUSS der Indexer sie stagen, sonst gehen sie verloren.

# Bluesky-Poller (importiert externe Antworten auf gecrosspostete Argumente).
# BSKY_POLL_ENABLED=false
# BSKY_POLL_INTERVAL_MS=...

# Peer-Review-Projektion (Quorum/Grace beim Auswerten der Responses) — müssen mit
# der appview übereinstimmen. Defaults = Code-Defaults.
# APPVIEW_PEER_REVIEW_QUORUM=...
# APPVIEW_PEER_REVIEW_GRACE_PERIOD_SECONDS=...

# Content languages (BCP-47). Keep identical to the appview. (In Kubernetes the
# indexer instead reads these from appview-secrets via indexer.yaml; this local
# value is only for dev.)
POLTR_LANGUAGES=de-CH,en-GB
POLTR_DEFAULT_LANGUAGE=de-CH
