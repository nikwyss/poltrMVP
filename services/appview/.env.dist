# # ./services/appview/.env
APPVIEW_POSTGRES_URL=postgresql://......
PDS_HOSTNAME=......
# BACKFILL_PORT=3001
# APPVIEW_LOG_LEVEL=DEBUG
PDS_ADMIN_PASSWORD=.....
# PDS_GOVERNANCE_ACCOUNT_DID=did:plc:3ch7iwf6od4szklpolupbv7o
# # PDS_INTERNAL_URL=http://pds.poltr.svc.cluster.local
PDS_INTERNAL_URL=http://localhost:2583
PDS_PUBLIC_HANDLE=.....

# # Email Configuration (dev mode - logs to console)
APPVIEW_SMTP_HOST=localhost
APPVIEW_SMTP_PORT=587
APPVIEW_SMTP_USER=
APPVIEW_SMTP_PASSWORD=
APPVIEW_FROM_EMAIL=......
APPVIEW_SMTP_USE_TLS=true

# Shared secret authenticating the frontend XRPC proxy so it may forward the real
# client IP (X-Poltr-Client-IP) to the rate limiter. MUST match the frontend's
# APPVIEW_PROXY_SECRET. Generate: openssl rand -hex 32. See doc/SECURITY_AUTH.md #1.
APPVIEW_PROXY_SECRET=......

# Global hourly circuit breaker for outbound auth emails (login + registration),
# layered on top of the per-IP and per-email throttles. ALERT logs a warning and
# keeps sending; CAP refuses new auth emails. See doc/SECURITY_AUTH.md #4.
APPVIEW_AUTH_EMAIL_ALERT_PER_HOUR=40
APPVIEW_AUTH_EMAIL_CAP_PER_HOUR=100

APPVIEW_SERVER_DID=did:web:app.poltr.info

# #Generiere einmalig einen 32-byte Key (Base64). => openssl rand -base64 32
# Master-Key-Split: USER-Key entschlüsselt User-App-Passwörter (auth_creds),
# GOV-Key die Governance-Creds (writer/CMS erben ihn via secretKeyRef). appview
# selbst nutzt nur den USER-Key. Auf Dev derselbe Wert.
APPVIEW_USER_CREDS_MASTER_KEY_B64=......
# APPVIEW_GOV_CREDS_MASTER_KEY_B64=......
APPVIEW_FRONTEND_URL=http://localhost:5173

APPVIEW_HOSTNAME=app.poltr.info
APPVIEW_PORT=3000
APPVIEW_SESSION_LIFETIME_DAYS=7

CMS_INTERNAL_SERVER_URL=http://localhost:3002
# Crosspost-Loop: in K8s läuft er im writer-Pod, NICHT in der appview-API.
# Lokal (ein Prozess) hier "true" setzen, wenn man Crossposts testen will.
APPVIEW_CROSSPOST_ENABLED=false
# APPVIEW_CROSSPOST_POLL_INTERVAL_SECONDS=30
APPVIEW_PEER_REVIEW_ENABLED=false
# Review-Assignment-Parameter (Defaults = Code-Defaults).
# APPVIEW_PEER_REVIEW_DAILY_LIMIT=3
# APPVIEW_PEER_REVIEW_INVITE_PROBABILITY=0.35
# APPVIEW_PEER_REVIEW_GRACE_PERIOD_SECONDS=...
# APPVIEW_PEER_REVIEW_HOOK_THROTTLE_SECONDS=...

# --- ATProto-native Deliberation (appview-Seite) ---
# Fest verdrahtet: appview schreibt user-authored Argumente/Responses/Requests
# IMMER ins eigene User-Repo (kein Producer-Flag mehr — seit Phase 7 entfernt).
# Der Indexer staged sie, der community-writer promotet sie. Kein Schalter nötig.



# Content languages (BCP-47 short codes). Keep identical in the indexer.
POLTR_LANGUAGES=de-CH,en-GB
POLTR_DEFAULT_LANGUAGE=de-CH
# POLTR_LANGUAGES=de-CH,en-GB,fr-CH,it-CH,rm


# # Argument/comment translation worker (Infomaniak AI Tools, OpenAI-compatible).
# # Reuses the same Infomaniak product + token as the calculator embeddings.
APPVIEW_TRANSLATE_ENABLED=true
APPVIEW_TRANSLATE_BASE_URL=https://api.infomaniak.com
APPVIEW_TRANSLATE_PRODUCT_ID=109114
APPVIEW_TRANSLATE_API_KEY=...
APPVIEW_TRANSLATE_MODEL=swiss-ai/Apertus-70B-Instruct-2509
# APPVIEW_TRANSLATE_POLL_INTERVAL_SECONDS=30
# APPVIEW_TRANSLATE_BATCH_SIZE=20
# Translate comments too? Off by default (high-volume → token saving).
# APPVIEW_TRANSLATE_COMMENTS_ENABLED=false
# Translate taxonomy topic nodes (name + introduction)? On by default.
# APPVIEW_TRANSLATE_TOPICS_ENABLED=true
# Per-user content-creation quotas (per user · ballot; daily = rolling 24h,
# ballot = lifetime). See src/routes/deliberation/quota.py.
APPVIEW_ARGUMENT_DAILY_LIMIT=2
APPVIEW_ARGUMENT_BALLOT_LIMIT=10
APPVIEW_COMMENT_DAILY_LIMIT=10
APPVIEW_COMMENT_BALLOT_LIMIT=50
